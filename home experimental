<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Blog &amp; Resources</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
<style>

/* ── Local Space Grotesk + Space Mono ── */
@font-face {
  font-family: 'Space Grotesk';
  font-weight: 300;
  src: url('fonts/SpaceGrotesk-Light.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Grotesk';
  font-weight: 400;
  src: url('fonts/SpaceGrotesk-Regular.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Grotesk';
  font-weight: 500;
  src: url('fonts/SpaceGrotesk-Medium.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Grotesk';
  font-weight: 600;
  src: url('fonts/SpaceGrotesk-SemiBold.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Grotesk';
  font-weight: 700;
  src: url('fonts/SpaceGrotesk-Bold.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Mono';
  font-weight: 400;
  font-style: normal;
  src: url('fonts/SpaceMono-Regular.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Mono';
  font-weight: 400;
  font-style: italic;
  src: url('fonts/SpaceMono-Italic.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Mono';
  font-weight: 700;
  font-style: normal;
  src: url('fonts/SpaceMono-Bold.ttf') format('truetype');
  font-display: swap;
}
@font-face {
  font-family: 'Space Mono';
  font-weight: 700;
  font-style: italic;
  src: url('fonts/SpaceMono-BoldItalic.ttf') format('truetype');
  font-display: swap;
}

@font-face {
  font-family: 'Inter';
  font-weight: 400;
  src: url('fonts/Inter-Regular.otf') format('opentype');
  font-display: swap;
}
@font-face {
  font-family: 'Inter';
  font-weight: 500;
  src: url('fonts/Inter-Medium.otf') format('opentype');
  font-display: swap;
}
@font-face {
  font-family: 'Inter';
  font-weight: 600;
  src: url('fonts/Inter-SemiBold.otf') format('opentype');
  font-display: swap;
}
@font-face {
  font-family: 'Inter';
  font-weight: 700;
  src: url('fonts/Inter-Bold.otf') format('opentype');
  font-display: swap;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {

  /* ── Elastic Design System Tokens ── */
  --color-bg-white:       #FFFFFF;
  --color-bg-light-gray:  #F5F7FA;
  --color-text-dark-ink:  #1C1E23;
  --color-text-ink:       #343741;
  --color-text-subdued:   #69707D;
  --color-border: var(--black);
  --color-elastic-blue:   #0B64DD;
  --color-teal:           #00BFB3;
  --font-display: 'Space Grotesk', sans-serif;
  --font-body:    'Inter', -apple-system, sans-serif;
  --font-mono:    'Roboto Mono', 'Courier New', monospace;

  /* ── Spacing — factor of 8 ── */
  --space-1:   4px;
  --space-2:   8px;
  --space-3:   12px;
  --space-4:   16px;
  --space-6:   24px;
  --space-8:   32px;
  --space-12:  48px;
  --space-16:  64px;
  --space-24:  96px;
  --space-32:  128px;

  /* ── Grid — 12 col, 96px margin, 32px gutter ── */
  --grid-margin:  96px;
  --grid-gutter:  32px;

  /* ── Page aliases ── */
  --black:       #111010;
  --white:       #FAFAF8;
  --cream:       #F5F7FA;
  --silver:      #D3DAE6;
  --warm-beige:  #F0BF75;
  --border:      #D3DAE6;
  --page-pad:    var(--grid-margin);
}

html {
  scroll-behavior: smooth; background: var(--white); color: var(--black); }
body { font-family: var(--font-body); font-size: 14px; line-height: 1.6; -webkit-font-smoothing: antialiased; background: var(--white); }
p { font-family: var(--font-body); }
img { display: block; max-width: 100%; }
a { text-decoration: none; color: inherit; }

/* ── CONTAINER — Elastic grid system ── */
.page-container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--grid-margin);
}
/* Full-bleed sections that constrain internally */
.full-bleed { width: 100%; }
.full-bleed .page-container { /* already constrained */ }

/* ── CATEGORY TICKER ── */
.ticker-bar {
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.ticker-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--grid-margin);
  display: flex;
  align-items: center;
  height: 46px;
  gap: 0;
}
.ticker-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 32px;
  border-right: 1px solid var(--border);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  white-space: nowrap;
  color: rgba(0,0,0,0.65);
  cursor: pointer;
  transition: color 0.15s;
}
.ticker-item:first-child { padding-left: 0; }
.ticker-item:hover { color: var(--black); }
.ticker-dot {
  width: 8px; height: 8px;
  border: 1.5px solid currentColor;
  border-radius: 1px;
  flex-shrink: 0;
}

/* ── PAGE HEADER ── */
.page-header {
  border-bottom: 1px solid var(--border);
}
.page-header-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: var(--space-16) var(--grid-margin) var(--space-12);
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: var(--space-8);
}
.blog-big-title {
  font-family: var(--font-display);
  font-size: 120px;
  font-weight: 500;
  line-height: 1.0;
  letter-spacing: -0.04em;
  color: var(--black);
}
.blog-subtitle {
  max-width: 420px;
  font-size: 15px;
  line-height: 1.6;
  color: rgba(0,0,0,0.55);
  font-weight: 500;
  margin-top: 8px;
  align-self: flex-end;
}

/* ── TABS ── */
.tabs-bar {
  border-bottom: 1px solid var(--border);
}
.tabs-bar-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--grid-margin);
  display: flex;
  align-items: center;
  gap: 0;
}
.tab-btn {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 16px 0;
  margin-right: 40px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  cursor: pointer;
  color: #595959;
  transition: color 0.15s, border-color 0.15s;
}
.tab-btn.active {
  color: var(--black);
  border-bottom-color: var(--black);
}
.tab-btn:hover { color: var(--black); }

/* ── SECTION HEADER ── */
.section-header {
  max-width: 1440px;
  margin: 0 auto;
  padding: var(--space-16) var(--grid-margin) 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.section-title {
  font-family: var(--font-display);
  font-size: 48px;
  font-weight: 500;
  line-height: 1.1;
  letter-spacing: -0.02em;
}
.section-link {
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border: 1px solid var(--black);
  padding: 8px 16px;
  border-radius: 4px;
  transition: background 0.15s, color 0.15s;
}
.section-link:hover { background: var(--black); color: var(--white); }

/* ── DIVIDER WITH CORNERS ── */
.section-divider-wrap {
  max-width: 1440px;
  margin: var(--space-6) auto var(--space-8);
  padding: 0 var(--grid-margin);
}
.section-divider {
  display: flex;
  align-items: center;
  height: 5px;
}
.section-divider::before,
.section-divider::after {
  content: '';
  width: 1px;
  height: 5px;
  background: var(--black);
  flex-shrink: 0;
}
.section-divider-line {
  flex: 1;
  height: 1px;
  background: var(--black);
}

/* ── PLACEHOLDER COLOURS (used by card-img-placeholder-inner) ── */
.ph-1 { background: #E8E3DB; }
.ph-2 { background: #DDE3E8; }
.ph-3 { background: #E3DDE8; }
.ph-4 { background: #E8E0DB; }
.ph-5 { background: #DBE8E3; }
.ph-6 { background: #E8DBDB; }
.ph-7 { background: #DBE3E8; }

/* ── RECENT BLOG GRID ── */
.recent-section {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--grid-margin);
}
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--grid-gutter);
  padding: var(--space-8) 0 var(--space-16);
}

/* ── BLOG CARD — exact Figma 22:24880 ── */
.blog-card {
  border: 1px solid var(--black);
  padding: 11px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
  transition: opacity 0.18s;
}
.blog-card:hover { opacity: 0.75; }

/* Top row: dots + dashed line + number */
.card-top-row {
  display: flex;
  align-items: center;
  gap: 10px;
  height: 12px;
}
.card-dots {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-shrink: 0;
}
.card-dot {
  width: 8px;
  height: 8px;
  border: 1px solid #2f2f2f;
  border-radius: 50px;
  flex-shrink: 0;
}
.card-dash-line {
  flex: 1;
  border: none;
  border-top: 1px dashed #2f2f2f;
  height: 0;
}
.card-num {
  font-family: var(--font-mono);
  font-size: 10px;
  color: #2f2f2f;
  white-space: nowrap;
  flex-shrink: 0;
}

/* Image — wrapped in its own 1px border */
.card-img-border {
  border: 1px solid var(--black);
  width: 100%;
  flex-shrink: 0;
  overflow: hidden;
  line-height: 0;
}
.card-img-border img,
.card-img-placeholder-inner {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}
.card-img-placeholder-inner {
  background: var(--cream);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Meta + title */
.card-body {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.card-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 4px;
}
.card-category {
  font-family: var(--font-body);
  font-size: 13px;
  color: #2f2f2f;
  line-height: 14.31px;
}
.card-byline {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-body);
  font-size: 13px;
  color: #2f2f2f;
  line-height: 14.31px;
}
.card-byline-sep {
  width: 1px;
  height: 11px;
  background: #a3a3a3;
  flex-shrink: 0;
}
.card-title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 20px;
  line-height: 24px;
  color: var(--black);
  letter-spacing: 0;
}

/* ── EDITOR'S CHOICE (full-width hero card) ── */
.editors-section {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--grid-margin) var(--space-16);
}
.editors-card {
  border: 1px solid var(--black);
  position: relative;
  cursor: pointer;
  overflow: hidden;
}
.editors-card:hover .editors-overlay { opacity: 0.6; }
.editors-img-wrap {
  width: 100%;
  aspect-ratio: 16/6;
  position: relative;
  overflow: hidden;
}
.editors-img-placeholder {
  width: 100%;
  height: 100%;
  background: #2a2420;
  display: flex;
  align-items: center;
  justify-content: center;
}
.editors-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%, transparent 100%);
  transition: opacity 0.3s;
}
.editors-text {
  position: absolute;
  top: 50px;
  left: 60px;
  max-width: 480px;
  color: var(--white);
}
.editors-category {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 16px;
  opacity: 0.75;
}
.editors-title {
  font-family: var(--font-display);
  font-size: 44px;
  font-weight: 500;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: 20px;
}
.editors-byline {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12px;
  opacity: 0.7;
}

/* ── SUBSCRIBE BANNER ── */
.subscribe-banner-wrap {
  max-width: 1440px;
  margin: 0 auto var(--space-16);
  padding: 0 var(--grid-margin);
}
.subscribe-banner {
  border: 1px solid var(--black);
  padding: var(--space-12);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}
.subscribe-text h3 {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 500;
  margin-bottom: 6px;
}
.subscribe-text p {
  font-size: 14px;
  color: rgba(0,0,0,0.55);
}
.subscribe-form {
  display: flex;
  align-items: center;
  border: 1px solid var(--black);
  border-radius: 0;
  overflow: hidden;
  min-width: 380px;
}
.subscribe-input {
  flex: 1;
  padding: 14px 20px;
  font-family: var(--font-body);
  font-size: 14px;
  border: none;
  outline: none;
  background: transparent;
  color: var(--black);
}
.subscribe-input::placeholder { color: rgba(0,0,0,0.35); }
.subscribe-btn {
  background: var(--black);
  color: var(--white);
  border: none;
  padding: 14px 24px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
}

/* ── FOOTER ── */
footer {
  background: var(--black);
  color: var(--white);
  margin-top: 120px;
}
.footer-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: var(--space-16) var(--grid-margin) var(--space-12);
}
.footer-top {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: var(--space-16);
  padding-bottom: var(--space-12);
  border-bottom: 1px solid rgba(255,255,255,0.15);
}
.footer-logo {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 600;
  margin-bottom: var(--space-8);
  letter-spacing: -0.02em;
}
.footer-subscribe-label {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 500;
  margin-bottom: 16px;
}
.footer-form {
  display: flex;
  border: 1px solid rgba(255,255,255,0.3);
  margin-bottom: 12px;
}
.footer-input {
  flex: 1;
  padding: 12px 16px;
  background: transparent;
  border: none;
  outline: none;
  color: var(--white);
  font-family: var(--font-body);
  font-size: 13px;
}
.footer-input::placeholder { color: rgba(255,255,255,0.35); }
.footer-btn {
  background: transparent;
  border: none;
  border-left: 1px solid rgba(255,255,255,0.3);
  color: var(--white);
  padding: 12px 20px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
}
.footer-small { font-size: 11px; color: #9e9e9e; }
.footer-cols {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-12);
}
.footer-col-title {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 500;
  margin-bottom: var(--space-4);
}
.footer-col a {
  display: block;
  font-size: 12px;
  color: #909090;
  margin-bottom: 10px;
  transition: color 0.15s;
}
.footer-col a:hover { color: var(--white); }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32px;
  font-size: 11px;
  color: rgba(255,255,255,0.35);
}
.footer-bottom-links { display: flex; gap: 24px; }
.footer-bottom-links a { color: #9e9e9e; transition: color 0.15s; }
.footer-bottom-links a:hover { color: var(--white); }

/* ── PLACEHOLDER ILLUSTRATIONS ── */
.ph-figure {
  width: 60%;
  height: 50%;
  opacity: 0.15;
  background: rgba(0,0,0,0.3);
  border-radius: 2px;
}
.ph-portrait {
  width: 40%;
  height: 80%;
  background: rgba(0,0,0,0.2);
  border-radius: 2px;
}

/* ══════════════════════════════════════════════════════════
   KNOWLEDGE BASE CARDS
══════════════════════════════════════════════════════════ */
.kb-panel {
  background: #0c0c0c;
  padding: var(--space-12);
  font-family: var(--font-body);
}
.kb-panel-hd {
  display: flex;
  gap: var(--space-6);
  margin-bottom: var(--space-8);
}
.kb-panel-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 22px;
  color: #cec0ad;
}
.kb-panel-link {
  font-size: 11px;
  color: #c67a3c;
  cursor: pointer;
  letter-spacing: 0.05em;
}
.kb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--grid-gutter);
}
.kb-card {
  position: relative;
  cursor: pointer;
  background: transparent;
  border: 1px solid var(--black);
  clip-path: polygon(0 0, calc(100% - 26px) 0, 100% 26px, 100% 100%, 0 100%);
  transition: background 0.1s ease;
  overflow: visible;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  padding: 36px;
}
.kb-title-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  min-height: 24px;
}
.kb-icon {
  width: 24px;
  height: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--black);
  align-self: center;
}
.kb-icon svg { width: 24px; height: 24px; display: block; }
.kb-title-row .kb-title {
  margin: 0;
  align-self: center;
}
.kb-card:hover .kb-icon { color: var(--black); }
.kb-card:hover { background: #ECEEF1; }
.kb-fold {
  position: absolute;
  top: -1px; right: -1px;
  width: 26px; height: 26px;
  pointer-events: none;
  z-index: 5;
  overflow: visible;
  transition: none;
}
.kb-fold-default { display: block; }
.kb-fold-hover   { display: none; }
.kb-card:hover .kb-fold-default { display: none; }
.kb-card:hover .kb-fold-hover   { display: block; }
.kb-image {
  width: calc(100% + 36px);
  margin: calc(-1 * var(--space-6)) -20px var(--space-4) calc(-1 * var(--space-4));
  height: 160px;
  background: #1a1a14;
  border-bottom: 1px solid rgba(206,192,173,0.3);
  overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 26px) 0, 100% 26px, 100% 100%, 0 100%);
}
.kb-image svg { width: 100%; height: 100%; display: block; }
.kb-card:hover .kb-image { border-bottom-color: rgba(58,46,30,0.3); }
.kb-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-body);
  font-size: 13px;
  line-height: 14.31px;
  color: #595959;
  margin-bottom: var(--space-3);
}
.kb-card:hover .kb-meta { color: #2f2f2f; }
.kb-av {
  width: 22px; height: 22px;
  border-radius: 50%;
  flex-shrink: 0;
  font-size: 14px;
  display: flex; align-items: center; justify-content: center;
}
.kb-title {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 600;
  line-height: 24px;
  letter-spacing: 0;
  color: var(--black);
  margin-bottom: var(--space-4);
}
.kb-card:hover .kb-title { color: var(--black); }
.kb-excerpt {
  font-family: var(--font-body);
  font-size: 13px;
  line-height: 1.6;
  color: #2f2f2f;
}
.kb-card:hover .kb-excerpt { color: #2f2f2f; }



/* ── FEATURED CARD — Figma 22:24632 ── */
.featured-row {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--grid-margin);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--grid-gutter);
  padding-bottom: var(--space-8);
}
.featured-card {
