<script>
function switchTab(btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}
function toggleExRow(trigger) {
  const row = trigger.closest('.ex-row');
  const panel = row.closest('.ex-panel');
  const wasOpen = row.classList.contains('is-open');
  // Close all sibling rows in the SAME panel
  if (panel) {
    panel.querySelectorAll('.ex-row.is-open').forEach(r => {
      if (r !== row) r.classList.remove('is-open');
    });
  }
  // Toggle the clicked row
  if (wasOpen) {
    row.classList.remove('is-open');
  } else {
    row.classList.add('is-open');
  }
}
function toggleSquareColor(sq) {
  sq.classList.toggle('is-black');
}
function toggleViewAll(btn) {
  const more = btn.parentElement.querySelector('.ex-rows-more');
  const txt  = btn.querySelector('.ex-viewall-text');
  const chev = btn.querySelector('.ex-viewall-chev');
  const collapsed = more.dataset.collapsed === 'true';
  if (collapsed) {
    more.dataset.collapsed = 'false';
    txt.textContent = 'View less';
    chev.style.transform = 'rotate(180deg)';
  } else {
    more.dataset.collapsed = 'true';
    txt.textContent = 'View all';
    chev.style.transform = 'rotate(0deg)';
  }
}

