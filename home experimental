  width: 100%;
  height: auto;
  display: block;
  overflow: visible;            /* allow paths that extend past the viewBox */
}
/* Ensure all page content floats above the bg art */
body { position: relative; }
.primary-nav, .secondary-nav, main, section, header, footer,
.hero-section-wrap, .examples-bg-section, .section-strip,
.fp-section, .cta-callout-section { position: relative; z-index: 1; }

