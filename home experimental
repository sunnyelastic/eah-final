<script>
/* ── Anchor scroll fix: re-scroll to hash after page fully loads ── */
/* When arriving from another page with a hash (e.g. #tutorial), the browser jumps
   before images/fonts settle, leaving the scroll position stale. This re-aligns. */
(function() {
  if (!window.location.hash) return;

  function scrollToHash() {
    var id = window.location.hash.slice(1);
    if (!id) return;
    var target = document.getElementById(id);
    if (!target) return;
    // Cancel browser's initial (stale) scroll, then smooth-scroll to the correct position
    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Run after window 'load' (everything: images, fonts, layout settled)
  if (document.readyState === 'complete') {
    setTimeout(scrollToHash, 50);
  } else {
    window.addEventListener('load', function() {
      setTimeout(scrollToHash, 50);
    });
  }
})();
</script>
